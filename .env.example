# 房间 PIN（4 位数字，留空则启动时随机生成并打印到控制台）
ROOM_PIN=

# 后端监听端口
PORT=8787

# Cloudflare Realtime TURN 凭证（强烈建议配置，否则跨境投屏 P2P 大概率打不通）
# 申请：https://dash.cloudflare.com → Realtime → TURN → Create TURN App
# 免费 1TB/月
CF_TURN_KEY_ID=
CF_TURN_API_TOKEN=

# Cloudflare Tunnel 模式（可选）
# 留空 → 用 quick tunnel（trycloudflare.com 临时域名，每次重启换 URL）
# 填名字 → 用 named tunnel（永久 URL，需先跑 cloudflared tunnel login + create + route dns）
TUNNEL_NAME=

# yt-dlp 走代理（可选，例如本地 clash: http://127.0.0.1:7890）
# 用于解析对当前服务器 IP 有反爬的网站
YTDLP_PROXY=

# yt-dlp cookies 文件路径（可选，用于绕登录墙）
YTDLP_COOKIES=
